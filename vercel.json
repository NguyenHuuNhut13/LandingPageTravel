{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.3"
        }
    },
    "routes": [
        {
            "src": "/css/(.*)",
            "dest": "/public/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/public/js/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/public/images/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array",
        "DB_CONNECTION": "sqlite",
        "DB_DATABASE": ":memory:",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
        "DATA_CACHE_DIR": "/tmp/storage/framework/cache",
        "APP_SERVICES_CACHE": "/tmp/storage/framework/services.php",
        "APP_PACKAGES_CACHE": "/tmp/storage/framework/packages.php",
        "APP_CONFIG_CACHE": "/tmp/storage/framework/config.php",
        "APP_ROUTES_CACHE": "/tmp/storage/framework/routes.php"
    }
}
